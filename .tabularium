{
  "$schema": "https://registry.tabularis.dev/manifest.schema.json?kind=driver",
  "name": "mongodb",
  "version": "0.1.0",
  "description": "MongoDB (6.0+) driver for Tabularis. Browse databases and collections, infer schemas by sampling documents, run native queries (find/aggregate/CRUD via db.coll.op(...)), manage indexes, and edit documents.",
  "category": "integration",
  "kind": "driver",
  "engine": "mongodb",
  "paradigms": ["document"],
  "tags": ["mongodb", "nosql", "document", "database-driver"],
  "license": "Apache-2.0",
  "homepage": "https://github.com/danielnuld/tabularis-mongodb-plugin",
  "documentation_url": "https://github.com/danielnuld/tabularis-mongodb-plugin/blob/main/README.md",
  "readme": "README.md",
  "support": {
    "issues_url": "https://github.com/danielnuld/tabularis-mongodb-plugin/issues"
  },
  "min_runtime_version": "0.9.13",
  "default_port": 27017,
  "color": "#13aa52",
  "executable": "tabularis-mongodb-plugin",
  "is_builtin": false,
  "capabilities": {
    "schemas": false,
    "views": true,
    "routines": false,
    "file_based": false,
    "folder_based": false,
    "connection_string": true,
    "connection_string_example": "mongodb://user:pass@localhost:27017/mydb",
    "identifier_quote": "\"",
    "alter_primary_key": false,
    "alter_column": false,
    "create_foreign_keys": false,
    "manage_tables": false,
    "readonly": false
  },
  "settings": [
    { "key": "uri", "label": "Connection String (optional)", "type": "string", "description": "Full MongoDB connection string, used verbatim when set (overrides host/port). e.g. mongodb+srv://user:pass@cluster.example.net/." },
    { "key": "srv", "label": "Use SRV (mongodb+srv)", "type": "boolean", "description": "DNS seedlist scheme, typical for MongoDB Atlas. Drops the port." },
    { "key": "auth_source", "label": "Auth Source", "type": "string", "description": "Authentication database (authSource), e.g. admin." },
    { "key": "replica_set", "label": "Replica Set", "type": "string", "description": "Replica set name (replicaSet)." },
    { "key": "tls", "label": "Enable TLS", "type": "boolean", "description": "Connect using TLS." },
    { "key": "sample_size", "label": "Schema Inference Sample Size", "type": "number", "description": "Documents sampled per collection to infer its columns." },
    { "key": "extra", "label": "Extra Connection Options", "type": "string", "description": "Extra connection-string query parameters appended verbatim, e.g. retryWrites=true&w=majority." }
  ],
  "data_types": [
    { "name": "STRING", "category": "string", "requires_length": false, "requires_precision": false },
    { "name": "INT32", "category": "numeric", "requires_length": false, "requires_precision": false },
    { "name": "INT64", "category": "numeric", "requires_length": false, "requires_precision": false },
    { "name": "DOUBLE", "category": "numeric", "requires_length": false, "requires_precision": false },
    { "name": "DECIMAL", "category": "numeric", "requires_length": false, "requires_precision": false },
    { "name": "BOOLEAN", "category": "other", "requires_length": false, "requires_precision": false },
    { "name": "DATE", "category": "date", "requires_length": false, "requires_precision": false },
    { "name": "OBJECTID", "category": "string", "requires_length": false, "requires_precision": false },
    { "name": "OBJECT", "category": "json", "requires_length": false, "requires_precision": false },
    { "name": "ARRAY", "category": "json", "requires_length": false, "requires_precision": false },
    { "name": "BINARY", "category": "binary", "requires_length": false, "requires_precision": false }
  ]
}
